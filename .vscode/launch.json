{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Wrangler (workerd)",
            "type": "node",
            "request": "attach",
            "port": 9229,
            "address": "127.0.0.1",
            "cwd": "/",
            "resolveSourceMapLocations": null,
            "attachExistingChildren": false,
            "autoAttachChildProcesses": false,
            "sourceMaps": true
        },
        {
            "name": "Wrangler: dev (local)",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/wrangler",
            "runtimeArgs": ["dev", "--inspector-port", "9229"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**"],
            "env": {
                "NODE_OPTIONS": "",
                "VSCODE_INSPECTOR_OPTIONS": ""
            },
            "serverReadyAction": {
                "action": "startDebugging",
                "pattern": "\\[wrangler:info\\] Ready on",
                "name": "Wrangler (workerd)"
            }
        }
    ]
}
